# ============================================================
# SOLBOT CONFIGURATION - Production Auto-Buy/Sell
# ============================================================

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Wallet (base58 private key) - not required for paper trading
WALLET_PRIVATE_KEY=

# Pump.fun WebSocket
PUMPFUN_WS_URL=wss://pumpportal.fun/api/data

# Jupiter API
JUPITER_API_URL=https://quote-api.jup.ag/v6

# ============================================================
# TRADING MODE
# ============================================================
# Paper Trading (true = simulate trades, false = live execution)
PAPER_TRADE=true

# Buy amount per trade
BUY_AMOUNT_SOL=0.1
SLIPPAGE_BPS=300
MAX_RETRIES=3
RETRY_DELAY_MS=500

# ============================================================
# FILTERS (pre-scoring)
# ============================================================
MIN_LIQUIDITY_SOL=5.0
MIN_MARKET_CAP_USD=10000
MAX_TOKEN_AGE_SECONDS=60

# ============================================================
# SCORING ENGINE
# ============================================================
# Weights (must sum to 1.0)
SCORE_WEIGHT_LIQUIDITY=0.30
SCORE_WEIGHT_CREATOR=0.20
SCORE_WEIGHT_BUY_PRESSURE=0.25
SCORE_WEIGHT_ANTI_RUG=0.25

# Confidence thresholds (composite score 0-100)
HIGH_CONFIDENCE_THRESHOLD=70.0
MEDIUM_CONFIDENCE_THRESHOLD=45.0

# Minimum confidence to execute a trade (LOW, MEDIUM, HIGH)
# Recommended: HIGH for production
MIN_TRADE_CONFIDENCE=HIGH

# ============================================================
# AUTO-SELL: STOP LOSS
# ============================================================
# Sell 100% if position drops X% from entry
STOP_LOSS_PCT=30.0

# ============================================================
# AUTO-SELL: TAKE PROFIT TIERS
# ============================================================
# Tier 1: Sell 30% at 2x
TP1_MULTIPLIER=2.0
TP1_SELL_PCT=0.30

# Tier 2: Sell 30% at 3x
TP2_MULTIPLIER=3.0
TP2_SELL_PCT=0.30

# Tier 3: Sell remaining 40% at 5x
TP3_MULTIPLIER=5.0
TP3_SELL_PCT=0.40

# ============================================================
# AUTO-SELL: TRAILING STOP
# ============================================================
# Trailing stop activates after position gains X% from entry
TRAILING_STOP_ACTIVATION_PCT=50.0

# Once activated, sell if price drops X% from the highest point
TRAILING_STOP_PCT=20.0

# ============================================================
# POSITION LIMITS
# ============================================================
# Maximum number of concurrent open positions
MAX_CONCURRENT_POSITIONS=5

# Minimum seconds between consecutive buys
BUY_COOLDOWN_SECONDS=10.0

# How often to check prices for auto-sell triggers (seconds)
PRICE_CHECK_INTERVAL=5.0

# ============================================================
# BLACKLIST
# ============================================================
# Auto-blacklist creators when rug conditions detected
AUTO_BLACKLIST_ENABLED=true

# Blacklist creator when their token hits stop loss
BLACKLIST_ON_STOP_LOSS=true

# ============================================================
# KILL SWITCH (emergency halt)
# ============================================================
# Enable automatic kill switch
KILL_SWITCH_ENABLED=true

# Halt all trading if cumulative realized loss exceeds this (SOL)
KILL_SWITCH_MAX_LOSS_SOL=1.0

# Halt all trading after X consecutive losing trades
KILL_SWITCH_MAX_CONSECUTIVE_LOSSES=5

# ============================================================
# PERSISTENCE
# ============================================================
# SQLite database path for positions, blacklist, trade history
DB_PATH=solbot_data.db

# ============================================================
# TELEGRAM ALERTS
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_RATE_LIMIT=3

# Alert types (individually toggleable)
TELEGRAM_ALERT_QUALIFIED=true
TELEGRAM_ALERT_TRADE=true
TELEGRAM_ALERT_SELL=true
TELEGRAM_ALERT_BLACKLIST=true

# ── Telegram Commands (remote management via OpenClaw) ──────────────
# Enable /status /positions /pnl /pause /resume /blacklist /kill /logs
TELEGRAM_COMMANDS_ENABLED=true

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=solbot.log

# ============================================================
# MARKET INTELLIGENCE (Real-time monitoring)
# ============================================================

# ── API Keys ────────────────────────────────────────────────────────
# Birdeye API key (for holder counts, security data)
# Get free key at https://birdeye.so
BIRDEYE_API_KEY=

# ── Polling Intervals ───────────────────────────────────────────────
# DexScreener poll interval (seconds) - free, no key needed
MARKET_INTEL_DEX_POLL_INTERVAL=5.0

# Birdeye poll interval (seconds) - lower rate limit
MARKET_INTEL_BIRDEYE_POLL_INTERVAL=30.0

# ── Rug Detection: Liquidity ────────────────────────────────────────
# Warn when LP drops X% from peak
MARKET_INTEL_LIQ_DRAIN_WARNING=30.0

# Exit position when LP drops X% from peak (critical)
MARKET_INTEL_LIQ_DRAIN_CRITICAL=50.0

# Auto-exit on critical LP drain
MARKET_INTEL_EXIT_ON_LIQ_CRITICAL=true

# ── Rug Detection: Volume & Sell Pressure ───────────────────────────
# Volume collapse threshold (% drop from baseline)
MARKET_INTEL_VOL_COLLAPSE_PCT=80.0

# Sell:buy ratio warning threshold
MARKET_INTEL_SELL_IMBALANCE_WARNING=3.0

# Sell:buy ratio critical threshold (auto-exit)
MARKET_INTEL_SELL_IMBALANCE_CRITICAL=5.0

# Auto-exit on critical sell dump
MARKET_INTEL_EXIT_ON_SELL_DUMP=true

# ── Momentum Detection ──────────────────────────────────────────────
# Alert on market cap spike (% increase in monitoring window)
MARKET_INTEL_MCAP_SPIKE_PCT=100.0

# Alert on volume surge (% increase from baseline)
MARKET_INTEL_VOL_SURGE_PCT=200.0

# Alert on holder growth surge (% increase)
MARKET_INTEL_HOLDER_SURGE_PCT=50.0

# ── Dynamic Trailing Stop ───────────────────────────────────────────
# Enable volatility-based trailing stop adjustment
MARKET_INTEL_DYNAMIC_TRAILING=true

# Trailing stop = volatility * this multiplier
MARKET_INTEL_VOL_TRAILING_MULT=2.5

# Never tighter than this (%)
MARKET_INTEL_MIN_TRAILING_PCT=10.0

# Never wider than this (%)
MARKET_INTEL_MAX_TRAILING_PCT=40.0

# ── Alerts ──────────────────────────────────────────────────────────
# Telegram alerts for rug warnings
MARKET_INTEL_ALERT_RUG_WARNING=true

# Telegram alerts for momentum surges
MARKET_INTEL_ALERT_MOMENTUM=true
