# ============================================================
# SOLBOT CONFIGURATION - Production Auto-Buy/Sell
# ============================================================

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Wallet (base58 private key) - not required for paper trading
WALLET_PRIVATE_KEY=

# Pump.fun WebSocket
PUMPFUN_WS_URL=wss://pumpportal.fun/api/data

# Jupiter API
JUPITER_API_URL=https://quote-api.jup.ag/v6

# ============================================================
# TRADING MODE
# ============================================================
# Paper Trading (true = simulate trades, false = live execution)
PAPER_TRADE=true

# Buy amount per trade
BUY_AMOUNT_SOL=0.1
SLIPPAGE_BPS=300
MAX_RETRIES=3
RETRY_DELAY_MS=500

# ============================================================
# FILTERS (pre-scoring)
# ============================================================
MIN_LIQUIDITY_SOL=5.0
MIN_MARKET_CAP_USD=10000
MAX_TOKEN_AGE_SECONDS=60

# ============================================================
# SCORING ENGINE
# ============================================================
# Weights (must sum to 1.0)
SCORE_WEIGHT_LIQUIDITY=0.30
SCORE_WEIGHT_CREATOR=0.20
SCORE_WEIGHT_BUY_PRESSURE=0.25
SCORE_WEIGHT_ANTI_RUG=0.25

# Confidence thresholds (composite score 0-100)
HIGH_CONFIDENCE_THRESHOLD=70.0
MEDIUM_CONFIDENCE_THRESHOLD=45.0

# Minimum confidence to execute a trade (LOW, MEDIUM, HIGH)
# Recommended: HIGH for production
MIN_TRADE_CONFIDENCE=HIGH

# ============================================================
# AUTO-SELL: STOP LOSS
# ============================================================
# Sell 100% if position drops X% from entry
STOP_LOSS_PCT=30.0

# ============================================================
# AUTO-SELL: TAKE PROFIT TIERS
# ============================================================
# Tier 1: Sell 30% at 2x
TP1_MULTIPLIER=2.0
TP1_SELL_PCT=0.30

# Tier 2: Sell 30% at 3x
TP2_MULTIPLIER=3.0
TP2_SELL_PCT=0.30

# Tier 3: Sell remaining 40% at 5x
TP3_MULTIPLIER=5.0
TP3_SELL_PCT=0.40

# ============================================================
# AUTO-SELL: TRAILING STOP
# ============================================================
# Trailing stop activates after position gains X% from entry
TRAILING_STOP_ACTIVATION_PCT=50.0

# Once activated, sell if price drops X% from the highest point
TRAILING_STOP_PCT=20.0

# ============================================================
# POSITION LIMITS
# ============================================================
# Maximum number of concurrent open positions
MAX_CONCURRENT_POSITIONS=5

# Minimum seconds between consecutive buys
BUY_COOLDOWN_SECONDS=10.0

# How often to check prices for auto-sell triggers (seconds)
PRICE_CHECK_INTERVAL=5.0

# ============================================================
# BLACKLIST
# ============================================================
# Auto-blacklist creators when rug conditions detected
AUTO_BLACKLIST_ENABLED=true

# Blacklist creator when their token hits stop loss
BLACKLIST_ON_STOP_LOSS=true

# ============================================================
# KILL SWITCH (emergency halt)
# ============================================================
# Enable automatic kill switch
KILL_SWITCH_ENABLED=true

# Halt all trading if cumulative realized loss exceeds this (SOL)
KILL_SWITCH_MAX_LOSS_SOL=1.0

# Halt all trading after X consecutive losing trades
KILL_SWITCH_MAX_CONSECUTIVE_LOSSES=5

# ============================================================
# PERSISTENCE
# ============================================================
# SQLite database path for positions, blacklist, trade history
DB_PATH=solbot_data.db

# ============================================================
# TELEGRAM ALERTS
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_RATE_LIMIT=3

# Alert types (individually toggleable)
TELEGRAM_ALERT_QUALIFIED=true
TELEGRAM_ALERT_TRADE=true
TELEGRAM_ALERT_SELL=true
TELEGRAM_ALERT_BLACKLIST=true

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=solbot.log
